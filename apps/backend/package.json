{
  "name": "backend",
  "version": "0.0.1",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '**/node_modules/**' --ignore '**/dist/**' src/app/index.ts",
    "build": "tsup src/app/index.ts --format esm,cjs --dts",
    "start": "NODE_ENV=production node dist/index.js",
    "lint": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write --ignore-unknown --log-level=warn",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:studio": "npx drizzle-kit studio",
    "test": "vitest --run --silent",
    "test:watch": "vitest --watch",
    "test:staged": "vitest related ./src/services/useCases/**/**/*.test.ts ./src/controllers/**/**/*.test.ts  --run",
    "test:ci": "vitest --run --coverage",
    "vitest:ui": "vitest --ui",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "prettier": "@curso-em-texto/prettier-config",
  "packageManager": "npm@8.5.0",
  "devDependencies": {
    "@curso-em-texto/eslint-config": "*",
    "@curso-em-texto/prettier-config": "*",
    "@curso-em-texto/vitest-config": "*",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/swagger": "^9.5.1",
    "@scalar/fastify-api-reference": "^1.34.2",
    "dotenv": "^17.2.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "zod": "^4.0.17"
  }
}
