{
  "name": "curso-em-texto",
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "lefthook install || echo 'Skipping lefthook'",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "docker": "docker compose -f ./apps/backend/docker-compose.yml --env-file ./apps/backend/.env up -d",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:staged": "turbo run test:staged",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck"
  },
  "packageManager": "npm@8.5.0",
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "overrides": {
    "esbuild": "0.25.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "lefthook": "^1.12.3",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6"
  }
}
